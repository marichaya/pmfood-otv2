PORT=3000
SESSION_SECRET=pmfood_secret_change_this_2024
NODE_ENV=development

# Turso Database (ได้จาก turso.tech)
# สำหรับ local dev ใช้ file:// ได้เลย ไม่ต้องสมัคร Turso
TURSO_URL=file:local.db
TURSO_AUTH_TOKEN=

# สำหรับ Render/Production ใส่ค่าจาก Turso dashboard:
# TURSO_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-token-here
